[Unit]
Description=Bridge Python Service
After=network.target

[Service]
ExecStartPre=/usr/bin/pkill -f bridge.py || true
ExecStart=/usr/bin/python3 /home/hoangnh/src/Bridge App/bridge.py
WorkingDirectory=/home/hoangnh/src/Bridge App
StandardOutput=inherit
StandardError=inherit
Restart=always
User=hoangnh

[Install]
WantedBy=multi-user.target
